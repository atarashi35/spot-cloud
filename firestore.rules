rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isResourceOwner(ownerUid) {
      return signedIn() && ownerUid == request.auth.uid;
    }

    function isActiveMember(spotId) {
      return signedIn()
        && exists(/databases/$(database)/documents/spots/$(spotId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/spots/$(spotId)/members/$(request.auth.uid)).data.status in ["active", "canceling"];
    }

    match /spots/{spotId} {
      allow read: if resource == null || resource.data.isPublished == true || isResourceOwner(resource.data.ownerUid);
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isResourceOwner(resource.data.ownerUid);

      match /members/{uid} {
        allow read: if signedIn() && (request.auth.uid == uid || isResourceOwner(get(/databases/$(database)/documents/spots/$(spotId)).data.ownerUid));
        // Memberships are payment-derived records. They must only be written by
        // trusted server code via the Admin SDK after Stripe/webhook validation.
        allow create, update, delete: if false;
      }

      match /posts/{postId} {
        // 公開投稿は誰でも、非公開はソシオ/オーナーのみ
        allow read: if resource.data.isPublic == true
                    || isActiveMember(spotId)
                    || isResourceOwner(get(/databases/$(database)/documents/spots/$(spotId)).data.ownerUid);
        allow create, update, delete: if isResourceOwner(get(/databases/$(database)/documents/spots/$(spotId)).data.ownerUid);
      }

      match /votes/{voteId} {
        // 読み取り: ソシオ・オーナーのみ
        allow read: if isActiveMember(spotId)
                    || isResourceOwner(get(/databases/$(database)/documents/spots/$(spotId)).data.ownerUid);
        // 作成・更新・削除: オーナーのみ（responseCount の increment も含む）
        allow create, delete: if isResourceOwner(get(/databases/$(database)/documents/spots/$(spotId)).data.ownerUid);
        allow update: if isResourceOwner(get(/databases/$(database)/documents/spots/$(spotId)).data.ownerUid)
                      || (isActiveMember(spotId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["responseCount", "updatedAt"]));

        match /responses/{uid} {
          // 本人の回答は本人とオーナーが読める
          allow read: if (signedIn() && request.auth.uid == uid)
                      || isResourceOwner(get(/databases/$(database)/documents/spots/$(spotId)).data.ownerUid);
          // オーナーは全回答を読める
          allow read: if isResourceOwner(get(/databases/$(database)/documents/spots/$(spotId)).data.ownerUid);
          // 回答はアクティブなソシオが自分のドキュメントにのみ作成可（更新・削除不可）
          allow create: if signedIn() && request.auth.uid == uid && isActiveMember(spotId);
        }
      }

      match /opinions/{opinionId} {
        // 読み取り: オーナーのみ
        allow read: if isResourceOwner(get(/databases/$(database)/documents/spots/$(spotId)).data.ownerUid);
        // 作成: アクティブなソシオ
        allow create: if isActiveMember(spotId);
        // isRead 更新: オーナーのみ
        allow update: if isResourceOwner(get(/databases/$(database)/documents/spots/$(spotId)).data.ownerUid)
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["isRead"]);
      }

      match /bookingRequests/{bookingRequestId} {
        // オーナーのみ閲覧可。組織者はFirebase Authを持たないため直接アクセスなし
        // （サーバーAPIがAdmin SDK経由でbookingRequestIdを認可トークンとして検証する）。
        allow read: if isResourceOwner(get(/databases/$(database)/documents/spots/$(spotId)).data.ownerUid);
        // 作成・金額系フィールドはAdmin SDK経由のみ。
        allow create, delete: if false;
        // オーナーはステータス遷移のみ可能（金額・Stripe関連フィールドはサーバーのみ）。
        allow update: if isResourceOwner(get(/databases/$(database)/documents/spots/$(spotId)).data.ownerUid)
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "declineReason", "updatedAt"]);
      }

      match /events/{eventId} {
        // 公開イベントは誰でも、非公開はソシオ/オーナーのみ
        allow read: if resource.data.isPublic == true
                    || isActiveMember(spotId)
                    || isResourceOwner(get(/databases/$(database)/documents/spots/$(spotId)).data.ownerUid);
        allow create, delete: if isResourceOwner(get(/databases/$(database)/documents/spots/$(spotId)).data.ownerUid);
        // participantCount is maintained by the server API transaction.
        allow update: if isResourceOwner(get(/databases/$(database)/documents/spots/$(spotId)).data.ownerUid);

        match /participants/{uid} {
          // 参加者の名前・メールはオーナーと本人のみ閲覧可。他ソシオには非公開（プライバシー保護）
          allow read: if (signedIn() && request.auth.uid == uid)
                      || isResourceOwner(get(/databases/$(database)/documents/spots/$(spotId)).data.ownerUid);
          // Participation writes are maintained by the server API transaction.
          allow create, update, delete: if false;
        }
      }
    }

    // collectionGroup クエリ用（公開投稿・イベントをトップページで横断取得）
    match /{path=**}/posts/{postId} {
      allow read: if resource.data.isPublic == true;
    }

    match /{path=**}/events/{eventId} {
      allow read: if resource.data.isPublic == true;
    }

    match /users/{uid} {
      // profileDisplayName など自分のプロフィールフィールドの読み書き
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /users/{uid}/memberships/{spotId} {
      allow read: if signedIn() && request.auth.uid == uid;
      // User membership mirrors are also payment-derived and are maintained by
      // trusted server code via the Admin SDK.
      allow write: if false;
    }

    match /users/{uid}/notifications/{notifId} {
      allow read: if signedIn() && request.auth.uid == uid;
      // 既読フラグの更新のみ許可（isRead フィールドのみ）
      allow update: if signedIn() && request.auth.uid == uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["isRead"]);
    }
  }
}
