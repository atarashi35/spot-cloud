rules_version = '2';
// Bucket: spot-cloud-27aaf.firebasestorage.app
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isOwnerNamespace(pathId) {
      return signedIn() && pathId == request.auth.uid;
    }

    function isAllowedSpotUpload() {
      return request.resource != null
        && request.resource.size <= 20 * 1024 * 1024
        && (
          request.resource.contentType.matches("image/(jpeg|png|webp)")
          || request.resource.contentType == "application/pdf"
        );
    }

    match /spots/{spotId}/{allPaths=**} {
      // 画像は誰でも読める（公開コンテンツ）
      allow read: if true;
      // Browser uploads live under spots/{uid}/... so users cannot overwrite
      // another owner's assets. Firestore owner rules still decide whether a
      // returned URL may be attached to a SPOT, post, or event.
      allow create, update: if isAllowedSpotUpload()
        && isOwnerNamespace(spotId);
      allow delete: if isOwnerNamespace(spotId);
    }

    match /avatars/{uid}/{allPaths=**} {
      // アバターは誰でも読める（カード表示・オーナー画面で使用）
      allow read: if true;
      // 本人のみ書き込める
      allow create, update: if signedIn()
        && request.auth.uid == uid
        && request.resource != null
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType == "image/webp";
      allow delete: if signedIn() && request.auth.uid == uid;
    }
  }
}
